{
  "name": "@grind-t/lib",
  "version": "1.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "npx @biomejs/biome check --write ./src",
    "test:unit": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.unit.test.ts\"",
    "test:e2e": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.e2e.test.ts\"",
    "test": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.test.ts\"",
    "check": "npm run typecheck && npm run lint && npm run test",
    "build": "tsup"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grind-t/lib.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/grind-t/lib/issues"
  },
  "homepage": "https://github.com/grind-t/lib#readme",
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@microsoft/api-extractor": "latest",
    "@swc/core": "latest",
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "latest"
  }
}
